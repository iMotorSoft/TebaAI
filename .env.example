# =============================================================================
# TebaAI - Configuration
#
# Environment variable prefix: TEBAAI_
#
# Variables are loaded through:
#   1. Shell environment (highest priority)
#   2. .env.backend-dev.local (sourced by backend-dev.sh)
#   3. core/config.py default values (lowest priority)
#
# Secrets (passwords, tokens, keys) must NEVER be committed.
# Leave them blank here and set them in your local environment.
# =============================================================================

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
TEBAAI_ENV=development
TEBAAI_DEBUG=false
TEBAAI_DEFAULT_LANGUAGE=es
TEBAAI_SUPPORTED_LANGUAGES=es,en,he

# ---------------------------------------------------------------------------
# PostgreSQL 18
#
# Required only when TEBAAI_POSTGRES_ENABLED=true.
# Precedence: TEBAAI_POSTGRES_DSN > individual fields.
# ---------------------------------------------------------------------------
TEBAAI_POSTGRES_ENABLED=false
TEBAAI_POSTGRES_HOST=127.0.0.1
TEBAAI_POSTGRES_PORT=5432
TEBAAI_POSTGRES_DB=tebaai
TEBAAI_POSTGRES_USER=
TEBAAI_POSTGRES_PASSWORD=
TEBAAI_POSTGRES_DSN=
TEBAAI_POSTGRES_MIN_POOL_SIZE=1
TEBAAI_POSTGRES_MAX_POOL_SIZE=10
TEBAAI_POSTGRES_CONNECT_TIMEOUT_SECONDS=10
TEBAAI_POSTGRES_APPLICATION_NAME=tebaai-backend
TEBAAI_POSTGRES_AUTO_MIGRATE=true

# ---------------------------------------------------------------------------
# Milvus 2.6
#
# Required only when TEBAAI_MILVUS_ENABLED=true.
# Precedence: TEBAAI_MILVUS_URI > host + port.
# ---------------------------------------------------------------------------
TEBAAI_MILVUS_ENABLED=false
TEBAAI_MILVUS_HOST=127.0.0.1
TEBAAI_MILVUS_PORT=19530
TEBAAI_MILVUS_URI=
TEBAAI_MILVUS_TOKEN=
TEBAAI_MILVUS_CONNECT_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# LiteLLM
#
# Required only when TEBAAI_LITELLM_ENABLED=true.
# ---------------------------------------------------------------------------
TEBAAI_LITELLM_ENABLED=false
TEBAAI_LITELLM_BASE_URL=http://127.0.0.1:4000
TEBAAI_LITELLM_API_KEY=
TEBAAI_LITELLM_DEFAULT_MODEL_ALIAS=
TEBAAI_LITELLM_TIMEOUT_SECONDS=60

# ---------------------------------------------------------------------------
# Auth (JWT)
#
# Required only when TEBAAI_AUTH_ENABLED=true.
# ---------------------------------------------------------------------------
TEBAAI_AUTH_ENABLED=false
TEBAAI_AUTH_JWT_SECRET=
TEBAAI_AUTH_JWT_ALGORITHM=HS256
TEBAAI_AUTH_ACCESS_TOKEN_TTL_MINUTES=15
TEBAAI_AUTH_REFRESH_TOKEN_TTL_DAYS=30
TEBAAI_AUTH_ISSUER=tebaai-api
TEBAAI_AUTH_AUDIENCE=tebaai-web
TEBAAI_AUTH_PASSWORD_PEPPER=

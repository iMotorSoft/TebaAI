---
import Layout from "../layouts/Layout.astro";
import HomePanel from "../components/HomePanel.svelte";
import { ROUTES } from "../components/global.js";
---

<Layout>
  <main class="page-shell">
    <HomePanel client:load />
    <nav class="mt-6">
      <a
        href={ROUTES.login}
        class="btn btn-ghost btn-sm rounded-full px-5"
      >
        Iniciar sesión
      </a>
    </nav>
  </main>
</Layout>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #17202a;
    background: #f6f7f9;
  }

  .page-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 32px;
  }
</style>
